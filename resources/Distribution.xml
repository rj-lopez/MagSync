<?xml version="1.0" encoding="utf-8"?>
<installer-gui-script minSpecVersion="2">
    <title>MagSync</title>
    <allowed-os-versions>
        <os-version min="15.0"/>
    </allowed-os-versions>
    <options hostArchitectures="arm64" customize="never" require-scripts="false" rootVolumeOnly="true"/>
    <choices-outline>
        <line choice="com.rjlopez.magsync.app"/>
        <line choice="com.rjlopez.magsync.helper"/>
    </choices-outline>
    <choice id="com.rjlopez.magsync.app" title="MagSync App" start_selected="true" start_enabled="false" start_visible="true">
        <pkg-ref id="com.rjlopez.magsync.app"/>
    </choice>
    <choice id="com.rjlopez.magsync.helper" title="SMC Helper (required)" start_selected="true" start_enabled="false" start_visible="true">
        <pkg-ref id="com.rjlopez.magsync.helper"/>
    </choice>
    <pkg-ref id="com.rjlopez.magsync.app" version="1.0" onConclusion="none">MagSync-app.pkg</pkg-ref>
    <pkg-ref id="com.rjlopez.magsync.helper" version="1.0" onConclusion="none">MagSync-helper.pkg</pkg-ref>
</installer-gui-script>
